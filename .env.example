# Use the hosted Supabase project values in production (for example, on Netlify).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Privy (identity: email/Google/wallet login + embedded Solana wallets).
# App ID and client ID are public; create them at dashboard.privy.io.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_PRIVY_CLIENT_ID=
# Privy pays network fees for embedded-wallet payments. Requires gas
# sponsorship activated for the app by the Privy team - keep false until then.
NEXT_PUBLIC_ENABLE_GAS_SPONSORSHIP=false

# Payments (featured listings). The treasury wallet receives USDC transfers;
# the mint defaults to mainnet USDC when unset — override it on devnet.
NEXT_PUBLIC_TREASURY_WALLET=your-treasury-wallet-address
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Server-only. Add these as secrets in the hosting provider; never expose them with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY: profile provisioning + local verification actions.
# PRIVY_APP_SECRET: verifies Privy access tokens (dashboard -> App settings).
# PRIVY_VERIFICATION_KEY (optional): skips the JWKS fetch on token checks.
# AUTH_JWT_SECRET: the Supabase project's JWT secret (Dashboard -> Settings ->
#   JWT Keys; locally the CLI demo secret below). Signs the session JWTs the
#   Privy exchange mints — also set it as an edge-function secret:
#   supabase secrets set AUTH_JWT_SECRET=...
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_VERIFICATION_KEY=
AUTH_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ENABLE_DEV_VERIFICATION=false
NEXT_PUBLIC_ENABLE_DEV_VERIFICATION=false
